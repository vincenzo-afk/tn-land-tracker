# TN Land Tracker — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Supabase
SUPABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_KEY=your_supabase_anon_key_here

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=tn-land-tracker-fmb
R2_PUBLIC_URL=https://pub-YOURTOKEN.r2.dev

# Backend CORS
FRONTEND_URL=http://localhost:3000
